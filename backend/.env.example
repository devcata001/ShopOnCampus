# ===============================================
# ShopOnCampus Backend Environment Configuration
# ===============================================

# JWT Secret for token signing
JWT_SECRET=your_jwt_secret_key_here

# MongoDB Connection
MONGO_URI=your_mongodb_connection_string

# Express Server Port
PORT=5000

# ===============================================
# EMAIL CONFIGURATION
# ===============================================
# IMPORTANT: Choose ONE approach below based on your deployment:

# OPTION 1: Gmail SMTP (Works on Localhost)
# Generate app password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# OPTION 2: Gmail OAuth2 (Works on Render & other PaaS)
# Required if SMTP is blocked on your platform
# Setup: https://developers.google.com/gmail/api/quickstart/nodejs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_ACCESS_TOKEN=your_google_access_token

# ===============================================
# FRONTEND CONFIGURATION
# ===============================================
# Allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://shoponcampus.vercel.app

# Frontend URLs
FRONTEND_URL=https://shoponcampus.vercel.app
FRONTEND_URL_DEV=http://localhost:3000

# ===============================================
# NODE ENVIRONMENT
# ===============================================
NODE_ENV=development

# ===============================================
# RENDER DEPLOYMENT (Auto-detected)
# ===============================================
# No need to set these manually - Render sets them automatically:
# - RENDER=true
# - RENDER_EXTERNAL_URL=https://your-app.onrender.com
